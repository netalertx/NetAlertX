        "name",
        "description"
      ],
      "name": [
        {
          "language_code": "en_us",
          "string": "User search filter"
        }
      ],
      "description": [
        {
          "language_code": "en_us",
          "string": "LDAP search filter used to locate the user entry. <code>{username}</code> is replaced with the sanitised login name at runtime. OpenLDAP example: <code>(uid={username})</code>. Active Directory example: <code>(sAMAccountName={username})</code>."
        }
      ]
    },
